---
# readability-redundant-parentheses is disabled because the Objective-C
# generator emits @(N) boxed-number literals where the parentheses are
# required for some operands (e.g. @(-2.2)) but redundant for others
# (e.g. @(30)). Emitting them uniformly keeps the generator simple.
Checks: >
  *,
  -altera-struct-pack-align,
  -cppcoreguidelines-avoid-magic-numbers,
  -fuchsia-default-arguments-calls,
  -google-objc-function-naming,
  -google-runtime-int,
  -hicpp-named-parameter,
  -llvm-include-order,
  -llvmlibc-callee-namespace,
  -llvmlibc-implementation-in-namespace,
  -llvmlibc-restrict-system-libc-headers,
  -misc-include-cleaner,
  -misc-use-internal-linkage,
  -modernize-raw-string-literal,
  -performance-unnecessary-value-param,
  -readability-implicit-bool-conversion,
  -readability-magic-numbers,
  -readability-named-parameter,
  -readability-redundant-parentheses,
WarningsAsErrors: '*'
