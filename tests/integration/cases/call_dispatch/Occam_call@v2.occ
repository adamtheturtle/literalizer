MOBILE DATA TYPE LIT IS
  CASE
    lit.null
    lit.bool ; BOOL
    lit.int ; INT
    lit.float ; REAL32
    lit.str ; MOBILE []BYTE
    lit.list ; MOBILE []MOBILE LIT
    lit.map ; MOBILE []MOBILE LIT
    lit.pair ; MOBILE []BYTE ; MOBILE LIT
    lit.set ; MOBILE []MOBILE LIT
:

PROC store_item (VAL MOBILE LIT key, VAL MOBILE LIT value)
    SKIP
:
PROC read_item (VAL MOBILE LIT key)
PROC main ()
    store_item(MOBILE LIT(lit.int; 1), MOBILE LIT(lit.int; 10))
    read_item(MOBILE LIT(lit.int; 1))
    SEQ
        SKIP
:
