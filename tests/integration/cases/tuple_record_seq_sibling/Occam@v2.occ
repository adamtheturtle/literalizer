MOBILE DATA TYPE LIT IS
  CASE
    lit.null
    lit.bool ; BOOL
    lit.int ; INT
    lit.float ; REAL32
    lit.str ; MOBILE []BYTE
    lit.list ; MOBILE []MOBILE LIT
    lit.map ; MOBILE []MOBILE LIT
    lit.pair ; MOBILE []BYTE ; MOBILE LIT
    lit.set ; MOBILE []MOBILE LIT
:

PROC main ()
    VAL MOBILE LIT my_data IS MOBILE LIT(lit.map; MOBILE []MOBILE LIT [
        MOBILE LIT(lit.pair; MOBILE []BYTE "scores"; MOBILE LIT(lit.list; MOBILE []MOBILE LIT [MOBILE LIT(lit.int; 10), MOBILE LIT(lit.int; 20), MOBILE LIT(lit.int; 30)])),
        MOBILE LIT(lit.pair; MOBILE []BYTE "args"; MOBILE LIT(lit.list; MOBILE []MOBILE LIT [MOBILE LIT(lit.int; 1), MOBILE LIT(lit.str; MOBILE []BYTE "email"), MOBILE LIT(lit.str; MOBILE []BYTE "a@gmail.com"), MOBILE LIT(lit.int; 100)]))
    ]):
    SEQ
        SKIP
:
