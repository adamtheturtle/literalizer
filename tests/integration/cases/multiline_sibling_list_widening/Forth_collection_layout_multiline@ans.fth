: my_data
+obj
    s\" omap_value" +key +obj
        s\" first" +key 1 +int
     -obj
    s\" sibling_lists" +key +obj
        s\" numbers" +key +arr
            1 +int
            2 +int
         -arr
        s\" strings" +key +arr
            s\" x" +str
            s\" y" +str
         -arr
     -obj
    s\" ref_marker_present" +key +arr
        s\" $keep" +str
        s\" z" +str
     -arr
 -obj
;
