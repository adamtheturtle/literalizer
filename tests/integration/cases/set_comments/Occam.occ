MOBILE DATA TYPE LIT IS
  CASE
    lit.null
    lit.bool ; BOOL
    lit.int ; INT
    lit.float ; REAL32
    lit.str ; MOBILE []BYTE
    lit.list ; MOBILE []MOBILE LIT
    lit.map ; MOBILE []MOBILE LIT
    lit.pair ; MOBILE []BYTE ; MOBILE LIT
    lit.set ; MOBILE []MOBILE LIT
:

PROC check ()
    VAL MOBILE LIT my_data IS MOBILE LIT(lit.set; MOBILE []MOBILE LIT [
        MOBILE LIT(lit.str; MOBILE []BYTE "apple"),  -- inline comment
        -- before banana
        MOBILE LIT(lit.str; MOBILE []BYTE "banana")
        -- trailing
    ]):
    SEQ
        SKIP
:
