MOBILE DATA TYPE LIT IS
  CASE
    lit.null
    lit.bool ; BOOL
    lit.int ; INT
    lit.float ; REAL32
    lit.str ; MOBILE []BYTE
    lit.list ; MOBILE []MOBILE LIT
    lit.map ; MOBILE []MOBILE LIT
    lit.pair ; MOBILE []BYTE ; MOBILE LIT
    lit.set ; MOBILE []MOBILE LIT
:

PROC main ()
    VAL MOBILE LIT my_data IS MOBILE LIT(lit.map; MOBILE []MOBILE LIT [
        -- Server configuration
        MOBILE LIT(lit.pair; MOBILE []BYTE "host"; MOBILE LIT(lit.str; MOBILE []BYTE "localhost")),  -- default host
        MOBILE LIT(lit.pair; MOBILE []BYTE "port"; MOBILE LIT(lit.int; 8080)),
        -- Enable debug mode
        MOBILE LIT(lit.pair; MOBILE []BYTE "debug"; MOBILE LIT(lit.bool; TRUE))
    ]):
    SEQ
        SKIP
:
