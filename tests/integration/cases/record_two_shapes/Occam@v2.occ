MOBILE DATA TYPE LIT IS
  CASE
    lit.null
    lit.bool ; BOOL
    lit.int ; INT
    lit.float ; REAL32
    lit.str ; MOBILE []BYTE
    lit.list ; MOBILE []MOBILE LIT
    lit.map ; MOBILE []MOBILE LIT
    lit.pair ; MOBILE []BYTE ; MOBILE LIT
    lit.set ; MOBILE []MOBILE LIT
:

PROC main ()
    VAL MOBILE LIT my_data IS MOBILE LIT(lit.map; MOBILE []MOBILE LIT [
        MOBILE LIT(lit.pair; MOBILE []BYTE "metrics"; MOBILE LIT(lit.map; MOBILE []MOBILE LIT [MOBILE LIT(lit.pair; MOBILE []BYTE "count"; MOBILE LIT(lit.int; 100)), MOBILE LIT(lit.pair; MOBILE []BYTE "rate"; MOBILE LIT(lit.int; 50))])),
        MOBILE LIT(lit.pair; MOBILE []BYTE "flags"; MOBILE LIT(lit.map; MOBILE []MOBILE LIT [MOBILE LIT(lit.pair; MOBILE []BYTE "retries"; MOBILE LIT(lit.int; 3)), MOBILE LIT(lit.pair; MOBILE []BYTE "timeout"; MOBILE LIT(lit.int; 30))]))
    ]):
    SEQ
        SKIP
:
