MOBILE DATA TYPE LIT IS
  CASE
    lit.null
    lit.bool ; BOOL
    lit.int ; INT
    lit.float ; REAL32
    lit.str ; MOBILE []BYTE
    lit.list ; MOBILE []MOBILE LIT
    lit.map ; MOBILE []MOBILE LIT
    lit.pair ; MOBILE []BYTE ; MOBILE LIT
    lit.set ; MOBILE []MOBILE LIT
:

PROC main (CHAN BYTE kyb?, scr!, err!)
    VAL MOBILE LIT my_data IS MOBILE LIT(lit.map; MOBILE []MOBILE LIT [
        MOBILE LIT(lit.pair; MOBILE []BYTE "date"; MOBILE LIT(lit.str; MOBILE []BYTE "2024-01-15")),
        MOBILE LIT(lit.pair; MOBILE []BYTE "datetime"; MOBILE LIT(lit.str; MOBILE []BYTE "2024-01-15T12:30:00+00:00"))
    ]):
    SEQ
        SKIP
:
