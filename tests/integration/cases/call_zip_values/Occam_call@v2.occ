MOBILE DATA TYPE LIT IS
  CASE
    lit.null
    lit.bool ; BOOL
    lit.int ; INT
    lit.float ; REAL32
    lit.str ; MOBILE []BYTE
    lit.list ; MOBILE []MOBILE LIT
    lit.map ; MOBILE []MOBILE LIT
    lit.pair ; MOBILE []BYTE ; MOBILE LIT
    lit.set ; MOBILE []MOBILE LIT
:

MOBILE LIT FUNCTION process (VAL MOBILE LIT value)
    RESULT MOBILE LIT(lit.null)
:
PROC emit (VAL MOBILE LIT _call, VAL MOBILE LIT _zip)
    SKIP
:
PROC main ()
    emit(process(MOBILE LIT(lit.str; MOBILE []BYTE "hello")), 1)
    emit(process(MOBILE LIT(lit.int; 42)), 0)
    SEQ
        SKIP
:
