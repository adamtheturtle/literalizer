MOBILE DATA TYPE LIT IS
  CASE
    lit.null
    lit.bool ; BOOL
    lit.int ; INT
    lit.float ; REAL32
    lit.str ; MOBILE []BYTE
    lit.list ; MOBILE []MOBILE LIT
    lit.map ; MOBILE []MOBILE LIT
    lit.pair ; MOBILE []BYTE ; MOBILE LIT
    lit.set ; MOBILE []MOBILE LIT
:

PROC main (CHAN BYTE kyb?, scr!, err!)
    VAL MOBILE LIT my_data IS MOBILE LIT(lit.map; MOBILE []MOBILE LIT [
        MOBILE LIT(lit.pair; MOBILE []BYTE "outer"; MOBILE LIT(lit.map; MOBILE []MOBILE LIT [MOBILE LIT(lit.pair; MOBILE []BYTE "a"; MOBILE LIT(lit.int; 1)), MOBILE LIT(lit.pair; MOBILE []BYTE "b"; MOBILE LIT(lit.str; MOBILE []BYTE "x")), MOBILE LIT(lit.pair; MOBILE []BYTE "c"; MOBILE LIT(lit.null))]))
    ]):
    SEQ
        SKIP
:
