MOBILE DATA TYPE LIT IS
  CASE
    lit.null
    lit.bool ; BOOL
    lit.int ; INT
    lit.float ; REAL32
    lit.str ; MOBILE []BYTE
    lit.list ; MOBILE []MOBILE LIT
    lit.map ; MOBILE []MOBILE LIT
    lit.pair ; MOBILE []BYTE ; MOBILE LIT
    lit.set ; MOBILE []MOBILE LIT
:

PROC main (CHAN BYTE kyb?, scr!, err!)
    VAL MOBILE LIT my_data IS MOBILE LIT(lit.list; MOBILE []MOBILE LIT [
        MOBILE LIT(lit.str; MOBILE []BYTE "C:\\path\\to\\file"),
        MOBILE LIT(lit.str; MOBILE []BYTE "back\\\\slash"),
        MOBILE LIT(lit.str; MOBILE []BYTE "hello \\\"world\\\""),
        MOBILE LIT(lit.str; MOBILE []BYTE "path\\to \"# file"),
        MOBILE LIT(lit.str; MOBILE []BYTE "trailing\\"),
        MOBILE LIT(lit.str; MOBILE []BYTE "both \"quotes''' here"),
        MOBILE LIT(lit.str; MOBILE []BYTE "line1\\nline2\nwith newline")
    ]):
    SEQ
        SKIP
:
