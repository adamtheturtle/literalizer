MOBILE DATA TYPE LIT IS
  CASE
    lit.null
    lit.bool ; BOOL
    lit.int ; INT
    lit.float ; REAL32
    lit.str ; MOBILE []BYTE
    lit.list ; MOBILE []MOBILE LIT
    lit.map ; MOBILE []MOBILE LIT
    lit.pair ; MOBILE []BYTE ; MOBILE LIT
    lit.set ; MOBILE []MOBILE LIT
:

MOBILE LIT FUNCTION record (VAL MOBILE LIT value)
    RESULT MOBILE LIT(lit.null)
:
PROC flush (VAL MOBILE LIT count)
    SKIP
PROC main ()
    record(MOBILE LIT(lit.int; 42))
    flush(MOBILE LIT(lit.int; 3))
    SEQ
        SKIP
:
