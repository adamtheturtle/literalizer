MOBILE DATA TYPE LIT IS
  CASE
    lit.null
    lit.bool ; BOOL
    lit.int ; INT
    lit.float ; REAL32
    lit.str ; MOBILE []BYTE
    lit.list ; MOBILE []MOBILE LIT
    lit.map ; MOBILE []MOBILE LIT
    lit.pair ; MOBILE []BYTE ; MOBILE LIT
    lit.set ; MOBILE []MOBILE LIT
:

PROC main ()
    VAL MOBILE LIT my_data IS MOBILE LIT(lit.list; MOBILE []MOBILE LIT [
        MOBILE LIT(lit.list; MOBILE []MOBILE LIT [MOBILE LIT(lit.str; MOBILE []BYTE "ADD"), MOBILE LIT(lit.str; MOBILE []BYTE "alice"), MOBILE LIT(lit.str; MOBILE []BYTE "hello")]),
        MOBILE LIT(lit.list; MOBILE []MOBILE LIT [MOBILE LIT(lit.str; MOBILE []BYTE "DEL"), MOBILE LIT(lit.str; MOBILE []BYTE "bob"), MOBILE LIT(lit.str; MOBILE []BYTE "5")])  -- removes "world"
    ]):
    SEQ
        SKIP
:
