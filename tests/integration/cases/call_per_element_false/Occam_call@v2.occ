MOBILE DATA TYPE LIT IS
  CASE
    lit.null
    lit.bool ; BOOL
    lit.int ; INT
    lit.float ; REAL32
    lit.str ; MOBILE []BYTE
    lit.list ; MOBILE []MOBILE LIT
    lit.map ; MOBILE []MOBILE LIT
    lit.pair ; MOBILE []BYTE ; MOBILE LIT
    lit.set ; MOBILE []MOBILE LIT
:

PROC process (VAL MOBILE LIT data)
    SKIP
:
PROC main ()
    process(MOBILE LIT(lit.int; 1))
    SEQ
        SKIP
:
