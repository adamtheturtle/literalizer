MOBILE DATA TYPE LIT IS
  CASE
    lit.null
    lit.bool ; BOOL
    lit.int ; INT
    lit.float ; REAL32
    lit.str ; MOBILE []BYTE
    lit.list ; MOBILE []MOBILE LIT
    lit.map ; MOBILE []MOBILE LIT
    lit.pair ; MOBILE []BYTE ; MOBILE LIT
    lit.set ; MOBILE []MOBILE LIT
:

PROC check ()
  VAL MOBILE LIT x IS MOBILE LIT(lit.list; MOBILE []MOBILE LIT [
    MOBILE LIT(lit.str; MOBILE []BYTE "2024-01-15"),
    MOBILE LIT(lit.str; MOBILE []BYTE "2024-06-30"),
    MOBILE LIT(lit.str; MOBILE []BYTE "2024-12-25")
]):
  SEQ
    SKIP
:
