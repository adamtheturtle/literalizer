MOBILE DATA TYPE LIT IS
  CASE
    lit.null
    lit.bool ; BOOL
    lit.int ; INT
    lit.float ; REAL32
    lit.str ; MOBILE []BYTE
    lit.list ; MOBILE []MOBILE LIT
    lit.map ; MOBILE []MOBILE LIT
    lit.pair ; MOBILE []BYTE ; MOBILE LIT
    lit.set ; MOBILE []MOBILE LIT
:

PROC main ()
    VAL MOBILE LIT my_data IS MOBILE LIT(lit.list; MOBILE []MOBILE LIT [
        MOBILE LIT(lit.int; 42),
        MOBILE LIT(lit.float; 3.14(REAL32)),
        MOBILE LIT(lit.bool; TRUE),
        MOBILE LIT(lit.bool; FALSE),
        MOBILE LIT(lit.str; MOBILE []BYTE "hello \"world\"")
    ]):
    SEQ
        SKIP
:
